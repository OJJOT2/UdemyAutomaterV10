# ============================================
# UdemyAutomaterV10 — Environment Variables
# ============================================

# --- Telegram Bot ---
# Get from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Your personal Telegram chat ID (get from @userinfobot)
ADMIN_CHAT_ID=your_admin_chat_id_here

# Public channel username (with @) or numeric channel ID
TELEGRAM_CHANNEL_ID=@your_channel_username

# --- WhatsApp (Baileys) ---
# WhatsApp Channel JID (format: channelId@newsletter)
WHATSAPP_CHANNEL_JID=

# Fallback: WhatsApp Group JID (format: groupId@g.us)
WHATSAPP_GROUP_JID=

# --- Google Gemini AI ---
# Get from https://aistudio.google.com/apikey
# You can provide multiple keys separated by commas.
# If one runs out of quota (429 error), the bot automatically switches to the next one!
GEMINI_API_KEYS=key1,key2,key3

# --- Scraper Config ---
# Max new courses to process per scrape cycle
MAX_COURSES_PER_RUN=100

# Number of courses to auto-post if 4 PM deadline is hit with 0 approvals
AUTO_POST_COUNT=10

# ============================================
# Cron Schedules (node-cron format)
# ============================================

# 8 AM Cairo — read poll winner, scrape that category, send to admin for review
MORNING_CRON=0 8 * * *

# 4 PM Cairo — if 0 posts approved today, auto-post AUTO_POST_COUNT courses + send poll
DEADLINE_CRON=0 16 * * *

# Optional legacy evening poll (leave empty to disable — poll is sent automatically
# after the pipeline and after auto-posting, so this is usually not needed)
POLL_CRON=

# --- Timezone ---
# Africa/Cairo = UTC+2, no DST (correct for Egypt)
# Asia/Amman   = UTC+2, observes DST (Jordan — different in summer)
TZ=Africa/Cairo
